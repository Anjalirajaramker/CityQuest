# Stage 1: Use an official NGINX image as the base
# NGINX is a very popular, high-performance web server.
FROM nginx:alpine

# Stage 2: Copy your website's files into the web server's main directory
# Copying only the Devops folder to avoid exposing sensitive repo files.
# The '/usr/share/nginx/html' is the default folder where NGINX serves files from.
COPY ./Devops /usr/share/nginx/html

# Stage 3: Tell Docker that the container will listen on port 80
EXPOSE 80
